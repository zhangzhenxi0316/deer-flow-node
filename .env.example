# ============================================================
# DeerFlow Node.js 环境配置
# 复制此文件为 .env 并填写实际配置
# ============================================================

# -------- LLM 提供商 (至少配置一个) --------
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1  # 可配置为代理地址

ANTHROPIC_API_KEY=sk-ant-...

MINIMAX_API_KEY=sk-api-CjtuLIEeKAH9N8PVT-NkRPwLQEPcAOvq_2vT3fiVoLNJ4KCBrC3e1tdkvRBUcOS4CgZ643pOq6uortCGoiIfO4FAVeY-pJYpoCbd1VWV4Zy2domIBnh5Bfg         # MiniMax API Key (https://platform.minimaxi.com)
MINIMAX_BASE_URL=            # 可选，默认 https://api.minimaxi.chat/v1

# -------- 默认使用的模型 --------
# 可选: openai, anthropic, minimax
DEFAULT_PROVIDER=minimax
DEFAULT_MODEL=MiniMax-Text-01

# -------- 工具 API Keys --------
TAVILY_API_KEY=tvly-...    # Web 搜索 (https://tavily.com)

# -------- Agent 服务配置 --------
AGENT_SERVER_PORT=3002
AGENT_SERVER_HOST=localhost

# -------- API 服务配置 --------
API_SERVER_PORT=3001
CORS_ORIGINS=http://localhost:5173

# -------- Web 前端配置 --------
# Vite 代理配置，对应 API 服务地址
VITE_API_URL=http://localhost:3001
